# API Configuration
# For Expo, use EXPO_PUBLIC_ prefix to expose variables to client-side code
# Copy this file to .env and update with your values

# API URL Configuration
# Option 1: Use localhost (automatically handled for each platform)
# - Web: http://localhost:3000/api/trpc
# - iOS Simulator: http://localhost:3000/api/trpc  
# - Android Emulator: Automatically converted to http://10.0.2.2:3000/api/trpc
# - Physical Devices: Use your computer's IP (e.g., http://192.168.1.100:3000/api/trpc)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/trpc

# Option 2: Use tunnel URL (works on all platforms)
# EXPO_PUBLIC_API_URL=https://3000-i71gq6sd7bfm36fxu2piq-d8436c31.us1.manus.computer/api/trpc

# Option 3: Use production URL
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com/api/trpc

# Option 4: Use your computer's IP for physical devices
# Find your IP: Windows (ipconfig) or Mac/Linux (ifconfig)
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000/api/trpc
