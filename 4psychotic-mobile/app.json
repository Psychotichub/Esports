{
  "expo": {
    "name": "4psychotic",
    "slug": "4psychotic-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "psychotic",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "owner": "psychotic",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 30000
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.psychotic.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is needed for video streaming",
        "NSMicrophoneUsageDescription": "Microphone access is needed for audio streaming"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0e1a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.psychotic.mobile",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "INTERNET"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro",
      "name": "4psychotic",
      "shortName": "4psychotic",
      "lang": "en",
      "scope": "/",
      "themeColor": "#0a0e1a",
      "backgroundColor": "#0a0e1a",
      "display": "standalone",
      "orientation": "portrait",
      "startUrl": "/",
      "meta": {
        "viewport": "width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0e1a"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "b73fb944-4b64-47ca-a7d6-241550b6d7cf"
      },
      "apiUrl": "http://localhost:3000",
      "youtubeChannelId": "UC_x5XG_6S8Gbq4bTfDxrj2w"
    }
  }
}
