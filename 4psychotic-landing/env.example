# ============================================
# 4psychotic - Environment Variables Example
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================
# Node Environment
# ============================================
# Set to "production" for production builds
NODE_ENV=development

# ============================================
# Server Configuration
# ============================================
# Port for the Express server (default: 3000)
PORT=3000

# ============================================
# MySQL Database Configuration
# ============================================
# MySQL connection string
# Format: mysql://[username:password@]host[:port]/database[?options]
# Examples:
#   - Local: mysql://root:password@localhost:3306/4psychotic
#   - Remote: mysql://user:pass@example.com:3306/4psychotic
#   - With SSL: mysql://user:pass@host:3306/db?ssl=true
DATABASE_URL=mysql://root:787223@localhost:3306/4psychotic

# ============================================
# Authentication & Security
# ============================================
# JWT secret key for signing cookies and tokens
# Generate a strong random string (e.g., using: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AES-256-GCM encryption key for storing OAuth tokens in the database.
# Must be exactly 32 bytes (256 bits).
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# OAuth Server URL — the public base URL of THIS server.
# Used as the base for /api/oauth/:platform/callback redirect URIs.
# Examples:
#   - Local dev:  http://localhost:3000
#   - Production: https://api.yourapp.com
OAUTH_SERVER_URL=http://localhost:3000

# Owner OpenID (your user's OpenID for admin access)
OWNER_OPEN_ID=your-owner-open-id-here

# App ID for OAuth (VITE_APP_ID)
VITE_APP_ID=your-app-id-here

# ============================================
# Enable background live-status polling in dev
# ============================================
# Set to "true" to start the polling service locally (it always runs in production).
ENABLE_LIVE_POLLING=false

# ============================================
# YouTube OAuth (replaces YOUTUBE_API_KEY)
# ============================================
# NOTE: YOUTUBE_API_KEY and YOUTUBE_CHANNEL_ID are NO LONGER NEEDED.
#       Live-stream detection is now fully OAuth-driven.
#       Each user connects their own channel through the in-app flow.
#
# How to get these values:
#   1. Go to https://console.cloud.google.com/
#   2. Create a project → Enable "YouTube Data API v3"
#   3. Credentials → Create OAuth 2.0 Client ID (Web Application)
#   4. Add Authorised Redirect URI:
#        http://localhost:3000/api/oauth/youtube/callback   (dev)
#        https://api.yourapp.com/api/oauth/youtube/callback (prod)
#   5. Copy Client ID and Client Secret below.

YOUTUBE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
YOUTUBE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Redirect URI must exactly match what you registered in Google Cloud Console.
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/youtube/callback

# ============================================
# Facebook / Meta OAuth
# ============================================
# How to get these values:
#   1. Go to https://developers.facebook.com/
#   2. Create an App → Add "Facebook Login" product
#   3. Settings → Basic → copy App ID and App Secret
#   4. Facebook Login → Settings → add Valid OAuth Redirect URI:
#        http://localhost:3000/api/oauth/facebook/callback   (dev)
#        https://api.yourapp.com/api/oauth/facebook/callback (prod)
#   5. Required permissions: pages_read_engagement, pages_show_list,
#        pages_read_user_content, pages_manage_posts

FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/facebook/callback

# ============================================
# TikTok OAuth
# ============================================
# How to get these values:
#   1. Go to https://developers.tiktok.com/
#   2. Create an App → Add "Login Kit" product
#   3. Copy Client Key and Client Secret
#   4. Add Redirect URI:
#        http://localhost:3000/api/oauth/tiktok/callback   (dev)
#        https://api.yourapp.com/api/oauth/tiktok/callback (prod)
#   5. Required scopes: user.info.basic, video.list

TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/tiktok/callback

# ============================================
# Forge API Configuration (Optional)
# ============================================
# Built-in Forge API URL (for image generation, LLM, data API, etc.)
BUILT_IN_FORGE_API_URL=https://api.forge.com

# Built-in Forge API Key
BUILT_IN_FORGE_API_KEY=your-forge-api-key-here

# ============================================
# Notes
# ============================================
# 1. Never commit .env files to version control
# 2. Use different values for development and production
# 3. Keep secrets secure and rotate them regularly
# 4. For production, use environment variables from your hosting provider
# 5. Make sure your MySQL database is running before starting the server
# 6. Run "npm run db:push" after first setup to create all DB tables
#    including the socialConnections table used for OAuth token storage